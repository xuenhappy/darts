// Configuration options
{
    //the services for segment plugin used
    "dservices": {
        "wtype.encoder": {
            "type": "LabelEncoder",
            "hx.file": "data/codes/type.hx.txt"
        },
        "wordpiece.dict": {
            "type": "WordPice",
            "base.dir": "data/models/codex"
        },
        "pinyin.encoder": {
            "type": "PinyinEncoder"
        }
    },
    //all the recognizers plugin
    "recognizers": {
        "inner.dict": {
            "type": "DictWordRecongnizer",
            "pbfile.path": "data/models/panda.pbs",
            "atom.mode": "false"
        },
        "pinyin.dict": {
            "type": "PinyinRecongnizer",
            "deps": {
                "pyin.encoder": "pinyin.encoder"
            }
        },
        "neural.span": {
            "type": "OnnxRecongnizer",
            "model.path": "data/models/neural/recognizer.onnx",
            "max.span": "5",
            "threshold": "0.5",
            "threshold.2": "0.5",
            "threshold.3": "0.5",
            "threshold.4": "0.5",
            "threshold.5": "0.5",
            "deps": {
                "wordpiece.name": "wordpiece.dict"
            }
        },
        "location.dict": {
            "type": "DictWordRecongnizer",
            "pbfile.path": "data/models/location.pbs",
            "atom.mode": "false"
        },
        "location.components": {
            "type": "AddressRecongnizer"
        }
    },
    // all the deciders plugins
    "deciders": {
        "ngram.decider": {
            "type": "BigramDecider",
            "dat.path": "data/models/ngram_dict.bdf"
        },
        "mini.decider": {
            "type": "MinCoverDecider"
        },
        "hybrid.decider": {
            "type": "HybridStatDecider",
            "dat.path": "data/models/ngram_dict.bdf",
            "bigram.weight": "4.0",
            "length.weight": "10.0",
            "length.power": "1.0",
            "token.penalty": "0.0",
            "unknown.penalty": "20.0"
        },
        "neural.decider": {
            "type": "OnnxDecider",
            "pmodel.path": "data/models/neural/indicator.onnx",
            "qmodel.path": "data/models/neural/quantizer.onnx",
            "deps": {
                "wordpiece.name": "wordpiece.dict",
                "tencode.name": "wtype.encoder"
            }
        },
        "location.decider": {
            "type": "AddressDecider",
            "dat.path": "data/models/location.bdf",
            "lexical.weight": "0.15"
        }
    },
    // all mode that the segment working
    "modes": {
        "faster": {
            "decider": "mini.decider",
            "recognizers": [
                "inner.dict"
            ]
        },
        "fast": {
            "decider": "ngram.decider",
            "recognizers": [
                "inner.dict"
            ]
        },
        "hybrid": {
            "decider": "hybrid.decider",
            "recognizers": [
                "inner.dict"
            ]
        },
        "pinyin": {
            "decider": "hybrid.decider",
            "recognizers": [
                "inner.dict",
                "pinyin.dict"
            ]
        },
        "neural": {
            "decider": "neural.decider",
            "recognizers": [
                "inner.dict",
                "neural.span"
            ]
        },
        "location": {
            "decider": "location.decider",
            "recognizers": [
                "location.dict",
                "location.components"
            ]
        }
    },
    //which model to load for default
    "default.mode": "hybrid"
}
